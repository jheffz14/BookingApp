                function refreshTable() {
                    $.ajax({
                        url: '@Url.Action("GetLatestBookings", "Booking")',
                        type: 'GET',
                        success: function (data) {
                            let tbody = '';
                            data.forEach(function (b) {
                                // Check if booking is still Pending (important!)
                                if (b.status === 'Pending') {
                                    tbody += `
                                    <tr>
                                        <td>${b.bookingID}</td>
                                        <td>${b.item}</td>
                                        <td>${b.department}</td>
                                        <td>${b.user}</td>
                                        <td>${b.quantity}</td>
                                        <td>${b.purpose}</td>
                                        <td>${b.dateRequested}</td>
                                        <td>${b.dateReturned}</td>
                                        <td>${b.status}</td>
                                        <td>${b.remarks}</td>
                                        <td>
                                            <a class="btn btn-primary btn-sm" href="/Booking/Edit/${b.bookingID}">Edit</a>
                                            <a class="btn btn-danger btn-sm" href="/Booking/Delete/${b.bookingID}">Delete</a>
                                        </td>
                                    </tr>
                                `;
                                }
                            });
                            $('#bookingTable tbody').html(tbody);
                        }
                    });
                }

                // Initial load
                refreshTable();

                // Refresh every 5 seconds
                setInterval(refreshTable, 5000);
    </script>
}
