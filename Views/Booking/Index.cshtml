@model System.Data.DataTable
@{
    ViewBag.Title = "Bookings";
}
<h2>Bookings</h2>
@*<p>
    @Html.ActionLink("Create New Booking", "Create", null, new { @class = "btn btn-success" })
</p>*@
<table class="table table-bordered table-striped" id="bookingTable">
    <thead>
        <tr>
            <th>Booking ID</th>
            <th>Item</th>
            <th>Department</th>
            <th>User</th>
            <th>Quantity</th>
            <th>Purpose</th>
            <th>Date Requested</th>
            @*<th>Date Borrowed</th>*@
            <th>Date Returned</th>
            <th>Status</th>
            <th>Remarks</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody id="bookingBody">
        @foreach (System.Data.DataRow row in Model.Rows)
        {
            <tr>
                <td>@row["bookingID"]</td>
                <td>@row["item_name"]</td>
                <td>@row["departmentName"]</td>
                <td>@row["username"]</td>
                <td>@row["quantity"]</td>
                <td>@row["purpose"]</td>
                @*<td>@(row["date_requested"] != DBNull.Value ? Convert.ToDateTime(row["date_requested"]).ToString("yyyy-MM-dd") : "")</td>*@
                <td>
                    @(row["date_requested"] != DBNull.Value
                        ? ((DateTime)row["date_requested"]).ToString("MM-dd-yyyy hh:mm tt")
                        : "")
                </td>
                @*<td>@(row["date_borrowed"] != DBNull.Value ? Convert.ToDateTime(row["date_borrowed"]).ToString("yyyy-MM-dd") : "")</td>*@
                <td>@(row["date_returned"] != DBNull.Value ? Convert.ToDateTime(row["date_returned"]).ToString("yyyy-MM-dd") : "")</td>
                <td>@row["status"]</td>
                <td>@row["remarks"]</td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { id = row["bookingID"] }, new { @class = "btn btn-primary btn-sm" })
                    @Html.ActionLink("Delete", "Delete", new { id = row["bookingID"] }, new { @class = "btn btn-danger btn-sm" })
                </td>
            </tr>
        }
    </tbody>
</table>
