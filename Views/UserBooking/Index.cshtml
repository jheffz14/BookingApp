@model System.Data.DataTable
@{
    ViewBag.Title = "Bookings";
}
<script>
       // serialize into a JS string literal to avoid breaking JS if role contains quotes
    var currentRole = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Context.Session.GetString("role") ?? ""));
</script>
<h2>Bookings</h2>

@* @if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
} *@
@{
    var successMsg = TempData["Success"]?.ToString();
    var warningMsg = TempData["Warning"]?.ToString();
    var errorMsg = TempData["Error"]?.ToString();
    TempData.Remove("Success");
    TempData.Remove("Warning");
    TempData.Remove("Error");
}

@if (successMsg != null)
{
    <div id="tempAlert" class="alert alert-success alert-dismissible fade show m-3" role="alert">
        <i class="bx bx-check-circle me-1"></i> @successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (warningMsg != null)
{
    <div id="tempAlert" class="alert alert-warning alert-dismissible fade show m-3" role="alert">
        <i class="bx bx-error me-1"></i> @warningMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (errorMsg != null)
{
    <div id="tempAlert" class="alert alert-danger alert-dismissible fade show m-3" role="alert">
        <i class="bx bx-x-circle me-1"></i> @errorMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}



<p>
   @*  @Html.ActionLink("Create New Booking", "Create", null, new { @class = "btn btn-success" }) *@
    @{
        var userType = Context.Session.GetString("role");
        var userName = Context.Session.GetString("userID");

        @if (userName != null)
        {
            @if (userType == "Users")
            {
                <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createBookingModal">
                    + Create New Booking
                </button>
            }
        }

    }
</p>
<table class="table table-bordered table-striped" id="bookingTable">
    <thead>
        <tr>
            <th>Booking ID</th>
            <th>Item</th>
            <th>Department</th>
            <th>User</th>
            <th>Quantity</th>
            <th>Purpose</th>
            <th>Date Requested</th>
            @*<th>Date Borrowed</th>*@
            <th>Date Returned</th>
            <th>Status</th>
            <th>Remarks</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody id="bookingBody">
        @if (Model != null && Model.Rows.Count > 0)
        {
            foreach (System.Data.DataRow row in Model.Rows)
            {
                <tr>
                    <td>@row["bookingID"]</td>
                    <td>@row["item_name"]</td>
                    <td>@row["departmentName"]</td>
                    <td>@row["userID"]</td>
                    <td>@row["quantity"]</td>
                    <td>@row["purpose"]</td>
                    @*<td>@(row["date_requested"] != DBNull.Value ? ((DateTime)row["date_requested"]).ToString("yyyy-MM-dd") : "")</td>*@
                    <td>
                        @(row["date_requested"] != DBNull.Value
                        ? ((DateTime)row["date_requested"]).ToString("MM-dd-yyyy hh:mm tt")
                        : "")
                    </td>

                    @*<td>@(row["date_borrowed"] != DBNull.Value ? ((DateTime)row["date_borrowed"]).ToString("yyyy-MM-dd") : "")</td>*@
                    <td>@(row["date_returned"] != DBNull.Value ? ((DateTime)row["date_returned"]).ToString("yyyy-MM-dd") : "")</td>
                    <td>@row["status"]</td>
                    <td>@row["remarks"]</td>
                    <td>
                        @*@Html.ActionLink("Edit", "Edit", new { id = row["bookingID"] }, new { @class = "btn btn-primary btn-sm" })
                    @Html.ActionLink("Delete", "Delete", new { id = row["bookingID"] }, new { @class = "btn btn-danger btn-sm" })*@
                        @{
                            string status = row["status"].ToString();
                            string role = Context.Session.GetString("role") ?? "";

                            if (role != "Users" || status != "Approved")
                            {
                                <button class="btn btn-primary btn-sm"
                                        onclick="openEditModal(
                                    '@row["bookingID"]',
                                    '@(row["date_requested"] != DBNull.Value ? ((DateTime)row["date_requested"]).ToString("yyyy-MM-ddTHH:mm") : "")',
                                    '@row["status"]',
                                    '@row["remarks"]'
                                    )">
                                    Edit
                                </button>

                                <button class="btn btn-danger btn-sm"
                                        onclick="openDeleteModal(
                                    '@row["bookingID"]',
                                    '@row["item_name"]',
                                    '@row["departmentName"]',
                                    '@row["userID"]',
                                    '@row["quantity"]',
                                    '@row["purpose"]',
                                    '@(row["date_requested"] != DBNull.Value ? ((DateTime)row["date_requested"]).ToString("MM-dd-yyyy hh:mm tt") : "")',
                                    '@row["status"]'
                                    )">
                                    Delete
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-secondary btn-sm" disabled>Edit</button>
                                <button class="btn btn-secondary btn-sm" disabled>Delete</button>
                            }
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="11" class="text-center">No bookings found.</td>
            </tr>
        }
           
        
    </tbody>
</table>


<!--Modals-->

<!-- Create Booking Modal -->
<div class="modal fade" id="createBookingModal" tabindex="-1" aria-labelledby="createBookingModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createBookingModalLabel">Create New Booking</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="UserBooking" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">

                    <!-- Item -->
                    <div class="mb-3">
                        <label class="form-label">Item</label>
                        <select name="itemID" class="form-control" required>
                            <option value="">-- Select Item --</option>
                            @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.Items)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>

                    <!-- Hidden fields -->
                    <input type="hidden" name="departmentID" value="@Context.Session.GetString("DepartmentID")" />
                    <input type="hidden" name="userID" value="@Context.Session.GetString("UserID")" />
                    <input type="hidden" name="status" value="Pending" />

                    <!-- Quantity -->
                    <div class="mb-3">
                        <label class="form-label">Quantity</label>
                        <input type="number" name="quantity" class="form-control" min="1" required />
                    </div>

                    <!-- Purpose -->
                    <div class="mb-3">
                        <label class="form-label">Purpose</label>
                        <input type="text" name="purpose" class="form-control" required />
                    </div>

                    <!-- Date Requested -->
                    <div class="mb-3">
                        <label class="form-label">Date & Time Requested</label>
                        <input type="datetime-local" name="date_requested" class="form-control" required />
                    </div>

                    <!-- Error message -->
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Submit</button>
                </div>
            </form>
        </div>
    </div>
</div>


<!-- Edit Booking Modal -->
<div class="modal fade" id="editBookingModal" tabindex="-1" aria-labelledby="editBookingModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editBookingModalLabel">Edit Booking</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" id="editBookingForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="bookingid" id="edit_bookingid" />

                    <!-- Date Requested -->
                    <div class="mb-3">
                        <label class="form-label">Date & Time Requested</label>
                        <input type="datetime-local" name="date_requested" id="edit_date_requested" class="form-control" required />
                    </div>

                    <!-- Status -->
                    <!-- Status dropdown in Edit Modal -->
                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select name="status" id="edit_status" class="form-control" required>
                            @if (Context.Session.GetString("role") == "Admin" ||
                                         Context.Session.GetString("role") == "Superadmin")
                            {
                               @*  <option value="Pending">Pending</option> *@     
                               <option value="Approved">Approved</option>
                                <option value="Disapproved">Disapproved</option>
                                <option value="Returned">Returned</option>
                            }
                            else
                            {
                                <option value="Pending">Pending</option>
                            }
                        </select>
                    </div>
                    <!-- Edit Booking Modal body - add this after Status -->
                    <div class="mb-3" id="dateReturnedGroup" style="display:none;">
                        <label class="form-label">Date Returned</label>
                        <input type="datetime-local" name="date_returned"
                               id="edit_date_returned" class="form-control" />
                    </div>


                    <!-- Remarks -->
                    <div class="mb-3">
                        <label class="form-label">Remarks</label>
                        <input type="text" name="remarks" id="edit_remarks" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Booking Modal -->
<div class="modal fade" id="deleteBookingModal" tabindex="-1" aria-labelledby="deleteBookingModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteBookingModalLabel">Delete Booking</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" id="deleteBookingForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="id" id="delete_bookingid" />
                    <h5>Are you sure you want to delete this booking?</h5>
                    <dl class="row mt-3">
                        <dt class="col-sm-4">Item</dt>
                        <dd class="col-sm-8" id="delete_item"></dd>
                        <dt class="col-sm-4">Department</dt>
                        <dd class="col-sm-8" id="delete_department"></dd>
                        <dt class="col-sm-4">User</dt>
                        <dd class="col-sm-8" id="delete_user"></dd>
                        <dt class="col-sm-4">Quantity</dt>
                        <dd class="col-sm-8" id="delete_quantity"></dd>
                        <dt class="col-sm-4">Purpose</dt>
                        <dd class="col-sm-8" id="delete_purpose"></dd>
                        <dt class="col-sm-4">Date Requested</dt>
                        <dd class="col-sm-8" id="delete_date"></dd>
                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8" id="delete_status"></dd>
                    </dl>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>




<!--End Modals-->





@section Scripts {
    <script src="~/Scripts/jquery-3.6.0.min.js"></script>

    <script>

        // =====================
        // Render bookings table
        // =====================
        function renderBookings(data) {
            let tbody = '';

            if (!data || data.length === 0) {
                tbody = '<tr><td colspan="11" class="text-center">No bookings found.</td></tr>';
            } else {
                data.forEach(function(b) {
                    let canEditDelete = !(currentRole === 'Users' &&
                                          (b.status === 'Approved' ||
                                           b.status === 'Returned' ||
                                           b.status === 'Disapproved'));

                    let safeRemarks = (b.remarks ?? '').replace(/'/g, "\\'");
                    let safePurpose = (b.purpose ?? '').replace(/'/g, "\\'");
                    let safeItem = (b.item ?? '').replace(/'/g, "\\'");
                    let safeDept = (b.department ?? '').replace(/'/g, "\\'");

                    let editButton = canEditDelete
                        ? `<button class="btn btn-primary btn-sm" onclick="openEditModal('${b.bookingID}', '${b.dateRequestedRaw ?? ''}', '${b.status}', '${safeRemarks}')">Edit</button>`
                        : `<button class="btn btn-secondary btn-sm" disabled>Edit</button>`;

                    let deleteButton = canEditDelete
                        ? `<button class="btn btn-danger btn-sm" onclick="openDeleteModal('${b.bookingID}', '${safeItem}', '${safeDept}', '${b.user}', '${b.quantity}', '${safePurpose}', '${b.dateRequested}', '${b.status}')">Delete</button>`
                        : `<button class="btn btn-secondary btn-sm" disabled>Delete</button>`;

                    tbody += `
                        <tr>
                            <td>${b.bookingID}</td>
                            <td>${b.item}</td>
                            <td>${b.department}</td>
                            <td>${b.user}</td>
                            <td>${b.quantity}</td>
                            <td>${b.purpose}</td>
                            <td>${b.dateRequested}</td>
                            <td>${b.dateReturned}</td>
                            <td>${b.status}</td>
                            <td>${b.remarks}</td>
                            <td>${editButton} ${deleteButton}</td>
                        </tr>
                    `;
                });
            }

            $('#bookingTable tbody').html(tbody);
        }

        // =====================
        // AJAX load
        // =====================
        $.ajax({
            url: '@Url.Action("GetLatestBookings", "UserBooking")',
            type: 'GET',
            success: renderBookings
        });

        setInterval(function () {
            $.ajax({
                url: '@Url.Action("GetLatestBookings", "UserBooking")',
                type: 'GET',
                success: renderBookings
            });
        }, 5000);

        // =====================
        // Edit Modal
        // =====================
        function openEditModal(id, dateRequested, status, remarks) {
            document.getElementById('edit_bookingid').value = id;
            document.getElementById('edit_date_requested').value = dateRequested;
            document.getElementById('edit_status').value = status;
            document.getElementById('edit_remarks').value = remarks;
            toggleDateReturned(status);

            document.getElementById('editBookingForm').action = '/UserBooking/Edit/' + id;

            var modal = new bootstrap.Modal(document.getElementById('editBookingModal'));
            modal.show();
        }

        document.getElementById('edit_status').addEventListener('change', function() {
            toggleDateReturned(this.value);
        });

        function toggleDateReturned(status) {
            var group = document.getElementById('dateReturnedGroup');
            var input = document.getElementById('edit_date_returned');

            if (status === 'Returned') {
                group.style.display = 'block';
                if (!input.value) {
                    var now = new Date();
                    var formatted = now.getFullYear() + '-' +
                        String(now.getMonth() + 1).padStart(2, '0') + '-' +
                        String(now.getDate()).padStart(2, '0') + 'T' +
                        String(now.getHours()).padStart(2, '0') + ':' +
                        String(now.getMinutes()).padStart(2, '0');
                    input.value = formatted;
                }
            } else {
                group.style.display = 'none';
                input.value = '';
            }
        }

        // =====================
        // Delete Modal
        // =====================
        function openDeleteModal(id, item, department, user, quantity, purpose, date, status) {
            document.getElementById('delete_bookingid').value = id;
            document.getElementById('delete_item').innerText = item;
            document.getElementById('delete_department').innerText = department;
            document.getElementById('delete_user').innerText = user;
            document.getElementById('delete_quantity').innerText = quantity;
            document.getElementById('delete_purpose').innerText = purpose;
            document.getElementById('delete_date').innerText = date;
            document.getElementById('delete_status').innerText = status;

            document.getElementById('deleteBookingForm').action = '/UserBooking/Delete/' + id;

            var modal = new bootstrap.Modal(document.getElementById('deleteBookingModal'));
            modal.show();
        }

        // =====================
        // Auto dismiss alerts
        // =====================
        window.addEventListener('DOMContentLoaded', function () {
            const alert = document.getElementById('tempAlert');
            if (alert) {
                setTimeout(function () {
                    alert.classList.remove('show');
                    setTimeout(function () { alert.remove(); }, 500);
                }, 4000);
            }
        });

    </script>
}
