@{
    TempData.Keep();
    string? currentPage = ViewContext.HttpContext.Request.Path;

    string appTitle = "Item Booking";
  
}
<style>
    #logoutID {
    margin-left:30px;
    }

     #toggleON {
        margin-left:30px;
        margin-top:10px;
        margin-bottom: 10px;
        }
        #toggleOFF {
        margin-left: 30px;
        margin-top: 10px;
        margin-bottom: 10px;
        }
</style>
<!-- Menu -->
@* ! Do this simple *@
<aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">

  @* ! Hide app brand if navbar-full *@
  <div class='app-brand demo @((@ViewData["navbarFull"] != null && Convert.ToBoolean(@ViewData["navbarFull"])) ? "d-xl-none" : "")'>
    <a asp-controller="Dashboards" asp-action="Index" class="app-brand-link">
      <span class="app-brand-logo demo">
        @await Html.PartialAsync("../_Partials/_Macros")
      </span>
    </a>

    <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto">
      <i class="icon-base bx bx-chevron-left d-block d-xl-none align-middle"></i>
    </a>
  </div>

  <div class="menu-divider mt-0"></div>

  <div class="menu-inner-shadow"></div>

  @* ! Full version menu-items *@
  <ul class="menu-inner py-1">

    <!-- Dashboards -->
    <li class='menu-item@(currentPage.EndsWith("/") || currentPage.StartsWith("/Dashboards/") ? " active open" : "")'>
      <a href="javascript:void(0);" class="menu-link menu-toggle">
        <i class="menu-icon icon-base bx bx-home-smile"></i>
        <div class="text-truncate" data-i18n="Dashboards">Dashboards</div>
     @*    <span class="badge rounded-pill bg-danger ms-auto">5</span> *@
      </a>
      <ul class="menu-sub">
        <li class='menu-item@(currentPage == "/" ? " active" : "")'>
          <a asp-controller="Dashboards" asp-action="Index" class="menu-link">
            <div class="text-truncate">View Booking</div>
          </a>
        </li>  
      </ul>
    </li>

   
        <!-- Utilities -->
        @{
            var userType = Context.Session.GetString("role");
            var userName = Context.Session.GetString("userID");

            // Define menu items per role — easy to add new ones here
            var adminMenuItems = new List<(string Controller, string Label, string Icon)>
                {
                ("UserBooking", "Booking List", "bx-receipt"),
                ("Status",     "Status List",        "bx-bar-chart-alt-2"),
                ("Item",     "Item List",        "bx-purchase-tag"),           
                };

            var superAdminMenuItems = new List<(string Controller, string Label, string Icon)>
                {
                ("UserBooking", "Booking List", "bx-receipt"),
                ("Status",     "Status List",        "bx-bar-chart-alt-2"),
                ("Item",     "Item List",        "bx-purchase-tag"),
                ("Users",     "User List",        "bx-user-plus"),
                ("Department",     "Department List",        "bx-buildings"), 
                };
            var usersMenuItems = new List<(string Controller, string Label, string Icon)>
                {
                ("UserBooking",    "Create Booking",       "bx-user-plus"),
                  ("Status",     "Status List",        "bx-bar-chart-alt-2"), 
                };
        }

        <li class='menu-item@(currentPage.StartsWith("/Booking") ||
                              currentPage.StartsWith("/UserBooking") ||
                              currentPage.StartsWith("/Status") ||
                              currentPage.StartsWith("/Item") ||
                              currentPage.StartsWith("/Department") || 
                              currentPage.StartsWith("/Users") ? " active open" : "")'>
            <a href="javascript:void(0);" class="menu-link menu-toggle">
                <i class="menu-icon icon-base bx bx-wrench"></i>
                <div class="text-truncate">@appTitle</div>
            </a>

            <ul class="menu-sub">
                @if (userName != null)
                {
                    @if (userType == "Admin")
                    {
                        @foreach (var item in adminMenuItems)
                        {
                            <li class='menu-item@(currentPage.StartsWith("/" + item.Controller) ? " active" : "")'>
                                <a href="@Url.Action("Index", item.Controller)" class="menu-link">
                                    <i class="menu-icon tf-icons bx @item.Icon"></i>
                                    <div>@item.Label</div>
                                </a>
                            </li>
                        }
                    }
                    else if (userType == "Superadmin")
                    {
                        @foreach (var item in superAdminMenuItems)
                        {
                            <li class='menu-item@(currentPage.StartsWith("/" + item.Controller) ? " active" : "")'>
                                <a href="@Url.Action("Index", item.Controller)" class="menu-link">
                                    <i class="menu-icon tf-icons bx @item.Icon"></i>
                                    <div>@item.Label</div>
                                </a>
                            </li>
                        }


                        <!-- Maintenance toggle -->
                       @*  @if (POSUTILSv4.Helpers.MaintenanceMode.IsEnabled)
                        {
                            <li class="menu-item px-3 py-1">
                                <a href="@Url.Action("ToggleMaintenance", "Pages")"
                                   class="btn btn-success btn-sm w-100"
                                   onclick="return confirm('Turn OFF maintenance mode?')">
                                    <i class="bx bx-check-circle me-1"></i> Maintenance ON — Turn OFF
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="menu-item px-3 py-1">
                                <a href="@Url.Action("ToggleMaintenance", "Pages")"
                                   class="btn btn-danger btn-sm w-100"
                                   onclick="return confirm('Turn ON maintenance mode?')">
                                    <i class="bx bx-wrench me-1"></i> Turn ON Maintenance
                                </a>
                            </li>
                        } *@

                    }
                    else if (userType == "Users")
                    {
                        @foreach (var item in usersMenuItems)
                        {
                            <li class='menu-item@(currentPage.StartsWith("/" + item.Controller) ? " active" : "")'>
                                <a href="@Url.Action("Index", item.Controller)" class="menu-link">
                                    <i class="menu-icon tf-icons bx @item.Icon"></i>
                                    <div>@item.Label</div>
                                </a>
                            </li>
                        }
                    }


                }
            </ul>
        </li>

        <!-- END -->




   
    <!-- Logout -->
       
        <li>
            <a class="dropdown-item" asp-controller="Login" asp-action="Logout" id="logoutLbl" >
                <i class="icon-base bx bx-power-off icon-md me-3" id="logoutID"></i><span>Log Out</span>
            </a>
        </li>
  </ul>

</aside>
<!-- / Menu -->





