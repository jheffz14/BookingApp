@{
    ViewData["Title"] = "Dashboard";
    string role = ViewBag.Role ?? "";
    var itemAvailability = ViewBag.ItemAvailability as System.Data.DataTable;
    var bookingSchedule = ViewBag.BookingSchedule as System.Data.DataTable;
}

<h4 class="fw-bold mb-4">Dashboard</h4>

@* ===== ADMIN SUMMARY CARDS ===== *@
@if (role == "Admin" || role == "Superadmin")
{
    <div class="row mb-4">
        <div class="col-sm-6 col-lg-3 mb-4">
            <a href="/UserBooking/Index" class="text-decoration-none">
                @* ✅ clickable *@
                <div class="card border-start border-warning border-4 h-100 dashboard-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="mb-1 text-muted">Pending</p>
                                <h3 class="fw-bold text-warning" id="count_pending">@ViewBag.PendingCount</h3>
                            </div>
                            <i class="bx bx-time-five text-warning" style="font-size:2.5rem;"></i>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-3 mb-4">
            <a href="/Status/Index?status=Approved" class="text-decoration-none">
                @* ✅ clickable *@
                <div class="card border-start border-success border-4 h-100 dashboard-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="mb-1 text-muted">Approved</p>
                                <h3 class="fw-bold text-success" id="count_approved">@ViewBag.ApprovedCount</h3>
                            </div>
                            <i class="bx bx-check-circle text-success" style="font-size:2.5rem;"></i>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-3 mb-4">
            <a href="/Status/Index?status=Returned" class="text-decoration-none">
                @* ✅ clickable *@
                <div class="card border-start border-info border-4 h-100 dashboard-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="mb-1 text-muted">
                                    Returned
                                    <small class="text-info">(@DateTime.Now.ToString("MMM yyyy"))</small>
                                </p>
                                <h3 class="fw-bold text-info" id="count_returned">@ViewBag.ReturnedCount</h3>
                            </div>
                            <i class="bx bx-undo text-info" style="font-size:2.5rem;"></i>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-3 mb-4">
            <a href="/Status/Index?status=Disapproved" class="text-decoration-none">
                @* ✅ clickable *@
                <div class="card border-start border-danger border-4 h-100 dashboard-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="mb-1 text-muted">Disapproved</p>
                                <h3 class="fw-bold text-danger" id="count_disapproved">@ViewBag.DisapprovedCount</h3>
                            </div>
                            <i class="bx bx-x-circle text-danger" style="font-size:2.5rem;"></i>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>
}

<div class="row">

    @* ===== ITEM AVAILABILITY ===== *@
    @{
        var userType = Context.Session.GetString("role");
        var userName = Context.Session.GetString("userID");
        @if (userName != null)
        {
            @if (userType == "Admin" || userType == "Superadmin")
            {
 

    <div class="col-lg-5 mb-4">
           <a href="/Item/Index" class="text-decoration-none">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bx bx-package me-1"></i> Item Availability
                </h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Item</th>
                            <th class="text-center">Total</th>
                            <th class="text-center">Borrowed</th>
                            <th class="text-center">Available</th>
                        </tr>
                    </thead>
                    <tbody id="itemAvailabilityBody">
                        @if (itemAvailability != null && itemAvailability.Rows.Count > 0)
                        {
                            foreach (System.Data.DataRow row in itemAvailability.Rows)
                            {
                                int total = Convert.ToInt32(row["total_stock"]);
                                int borrowed = Convert.ToInt32(row["borrowed"]);
                                int available = Convert.ToInt32(row["available"]);
                                string badgeClass = available == 0 ? "danger"
                                                  : available <= 2 ? "warning"
                                                  : "success";

                                <tr>
                                    <td>@row["item_name"]</td>
                                    @if (role == "Admin" || role == "Superadmin")
                                    {
                                        <td class="text-center">@total</td>
                                        <td class="text-center">@borrowed</td>
                                    }
                                    <td class="text-center">
                                        <span class="badge bg-@badgeClass">
                                            @(available == 0 ? "None" : available.ToString())
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-3">No items found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        </a>
    </div>

                  
            }
        }

    }
    <!--end item availability-->


    @* ===== BOOKING SCHEDULE ===== *@
       @*  <div class="col-lg-7 mb-4" style="width:100%;"> *@
    <div class="@(role == "Users" ? "col-lg-7 mb-4" : "col-lg-7 mb-4")" @(role == "Users" ? "style=width:100%;" : "")>
        <div class="card h-100" > 
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bx bx-calendar me-1"></i>
                    @(role == "Users" ? "My Department Bookings" : "Active Booking Schedule")
                </h5>
                <span class="badge bg-primary">Pending &amp; Approved</span>
            </div>
            <div class="card-body p-0">
                <div style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-hover mb-0">
                        <thead class="table-light" style="position:sticky;top:0;">
                            <tr>
                                <th>Item</th>
                                <th>User</th>
                                <th>Department</th>
                                <th>Qty</th>
                                <th>Date Requested</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="bookingScheduleBody">
                            @if (bookingSchedule != null && bookingSchedule.Rows.Count > 0)
                            {
                                foreach (System.Data.DataRow row in bookingSchedule.Rows)
                                {
                                    string status = row["status"].ToString() ?? "";
                                    string statusClass = status == "Approved" ? "success"
                                                       : status == "Pending" ? "warning"
                                                       : "secondary";
                                    <tr>
                                        <td>@row["item_name"]</td>
                                        <td>@row["userID"]</td>
                                        <td>@row["departmentName"]</td>
                                        <td>@row["quantity"]</td>
                                        <td>
                                            @(row["date_requested"] != DBNull.Value
                                                ? ((DateTime)row["date_requested"]).ToString("MM-dd-yyyy hh:mm tt")
                                                : "")
                                        </td>
                                        <td>
                                           @*  <span class="badge bg-@statusClass">@status</span> *@
                                            @{
                                                string statusUrl = status == "Pending"
                                                    ? "/UserBooking/Index"
                                                    : status == "Approved"
                                                    ? "/Status/Index?status=Approved"
                                                    : "#";
                                            }
                                            <a href="@statusUrl" class="badge bg-@statusClass text-decoration-none">
                                                @status
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-3">
                                        No active bookings.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>      
</div>
        
@section Scripts {
    <script>
        var currentRole = '@Html.Raw(System.Text.Json.JsonSerializer.Serialize(role))';
        
        // Parse the role string (remove quotes if present)
        var role = currentRole.replace(/^"|"$/g, '');

        function renderDashboard(data) {
              // ✅ Guard against missing data
        if (!data || data.error) {
            console.log('Dashboard data error:', data?.error);
            return;
        }
                     // ===== ITEM AVAILABILITY =====
            let itemAvailBody = document.getElementById('itemAvailabilityBody');
            if (itemAvailBody && data.items) {
                let itemRows = '';
                data.items.forEach(function(item) {
                    let badgeClass = item.available === 0 ? 'danger'
                                   : item.available <= 2 ? 'warning'
                                   : 'success';
                    let availText = item.available === 0 ? 'None' : item.available;

                    let adminCols = '';
                    if (role === 'Admin' || role === 'Superadmin') {
                        adminCols = `<td class="text-center">${item.total}</td>
                                     <td class="text-center">${item.borrowed}</td>`;
                    }

                    itemRows += `
                        <tr>
                            <td>${escapeHtml(item.itemName)}</td>
                            ${adminCols}
                            <td class="text-center">
                                <span class="badge bg-${badgeClass}">${availText}</span>
                            </td>
                        </tr>`;
                });

                itemAvailBody.innerHTML = itemRows ||
                    '<tr><td colspan="4" class="text-center text-muted py-3">No items found.</td></tr>';
            }

            // ===== BOOKING SCHEDULE =====
            let scheduleBody = document.getElementById('bookingScheduleBody');
            if (scheduleBody && data.schedule) {
                let scheduleRows = '';
                data.schedule.forEach(function(b) {
                    let statusClass = b.status === 'Approved' ? 'success'
                                    : b.status === 'Pending' ? 'warning'
                                    : 'secondary';
                    // scheduleRows += `
                    //     <tr>
                    //         <td>${escapeHtml(b.itemName)}</td>
                    //         <td>${escapeHtml(b.userID)}</td>
                    //         <td>${escapeHtml(b.department)}</td>
                    //         <td>${b.quantity}</td>
                    //         <td>${b.dateRequested}</td>
                    //         <td><span class="badge bg-${statusClass}">${escapeHtml(b.status)}</span></td>
                    //     </tr>`;
                            let statusUrl = b.status === 'Pending' ? '/UserBooking/Index'
                      : b.status === 'Approved' ? '/Status/Index?status=Approved'
                      : '#';

        scheduleRows += `
            <tr>
                <td>${escapeHtml(b.itemName)}</td>
                <td>${escapeHtml(b.userID)}</td>
                <td>${escapeHtml(b.department)}</td>
                <td>${b.quantity}</td>
                <td>${b.dateRequested}</td>
                <td>
                    <a href="${statusUrl}" class="badge bg-${statusClass} text-decoration-none">
                        ${escapeHtml(b.status)}
                    </a>
                </td>
            </tr>`;
                });

                scheduleBody.innerHTML = scheduleRows ||
                    '<tr><td colspan="6" class="text-center text-muted py-3">No active bookings.</td></tr>';
            }

            // ===== SUMMARY COUNTS (Admin only) =====
            if ((role === 'Admin' || role === 'Superadmin') && data.summary) {
                let pending = document.getElementById('count_pending');
                let approved = document.getElementById('count_approved');
                let returned = document.getElementById('count_returned');
                let disapproved = document.getElementById('count_disapproved');

                if (pending) pending.textContent = data.summary.pending;
                if (approved) approved.textContent = data.summary.approved;
                if (returned) returned.textContent = data.summary.returned;
                if (disapproved) disapproved.textContent = data.summary.disapproved;
            }
        }

        // Helper function to prevent XSS attacks
        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function refreshDashboard() {
            fetch('@Url.Action("GetDashboardData", "Dashboards")')
                .then(r => r.json())
                .then(data => renderDashboard(data))
                .catch(err => console.log('Dashboard refresh error:', err));
        }

        // Initial load
        refreshDashboard();

        // ✅ Auto refresh every 5 seconds
        setInterval(refreshDashboard, 5000);
    </script>
}
