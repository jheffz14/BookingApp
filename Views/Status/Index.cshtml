@model System.Data.DataTable
@{
    string currentStatus = ViewBag.CurrentStatus ?? "Approved";
    string[] statusList = ViewBag.StatusList ?? new[] { "Approved", "Disapproved", "Returned" };
    ViewBag.Title = char.ToUpper(currentStatus[0]) + currentStatus.Substring(1) + " Bookings";

    // ✅ Core session
    string currentRole = Context.Session.GetString("role") ?? "";
}

<script>
    var currentRole = '@Html.Raw(System.Text.Json.JsonSerializer.Serialize(currentRole))';
    var currentStatus = '@currentStatus';

    var newBookingCounts = { 'Approved': 0, 'Disapproved': 0, 'Returned': 0 };
    var lastKnownBookings = { 'Approved': [], 'Disapproved': [], 'Returned': [] };
</script>

<link rel="stylesheet" href="~/css/filter-form.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/notifications.css" asp-append-version="true" />


<h2>@ViewBag.Title</h2>

<div class="mb-3">
    <form method="get" class="filter-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="status" value="@ViewBag.CurrentStatus" />
        <div class="filter-container">
            <div class="filter-group">
                <label for="startDate" class="filter-label">Start Date:</label>
                <input type="date" id="startDate" name="startDate"
                       value="@ViewBag.StartDate" class="form-control form-control-sm" />
            </div>
            <div class="filter-group">
                <label for="endDate" class="filter-label">End Date:</label>
                <input type="date" id="endDate" name="endDate"
                       value="@ViewBag.EndDate" class="form-control form-control-sm" />
            </div>
            <button type="submit" class="btn btn-primary btn-sm filter-btn">Filter</button>
        </div>
    </form>
</div>

<!-- Status Tabs -->
<div class="mb-4">
    <div class="btn-group" role="group">
        @foreach (var status in statusList)
        {
            <a href="@Url.Action("Index", new { status = status })"
                   class="btn @(status == currentStatus ? "btn-primary" : "btn-outline-primary") position-relative">
                @status
                <span id="badge-@status.ToLower()" class="badge-count" style="display:none;"></span>
            </a>
        }
    </div>
</div>

<!-- Table -->
<table class="table table-bordered table-striped" id="bookingTable">
    <thead>
        <tr>
            <th>Booking ID</th>
            <th>Item</th>
            <th>Department</th>
            <th>User</th>
            <th>Quantity</th>
            <th>Purpose</th>
            <th>Date Requested</th>
            <th>Date Returned</th>
            <th>Status</th>
            <th>Remarks</th>  @* ✅ removed duplicate *@
            @if (currentRole != "Users")  @* ✅ Core session *@
            {
                <th id="actionHeader">Action</th>
            }
        </tr>
    </thead>
    <tbody id="bookingBody">
        @if (Model != null && Model.Rows.Count > 0)
        {
            foreach (System.Data.DataRow row in Model.Rows)
            {
                string rowStatus = row["status"].ToString() ?? "";

                <tr>
                    <td>@row["bookingID"]</td>
                    <td>@row["item_name"]</td>
                    <td>@row["departmentName"]</td>
                    <td>@row["userID"]</td>
                    <td>@row["quantity"]</td>
                    <td>@row["purpose"]</td>
                    <td>
                        @(row["date_requested"] != DBNull.Value
                            ? ((DateTime)row["date_requested"]).ToString("MM-dd-yyyy hh:mm tt") : "")
                    </td>
                    <td>
                        @(row["date_returned"] != DBNull.Value
                            ? ((DateTime)row["date_returned"]).ToString("MM-dd-yyyy hh:mm tt") : "")
                    </td>
                    <td>@row["status"]</td>
                    <td>@row["remarks"]</td>
                    @if (currentRole != "Users")  @* ✅ Core session *@
                    {
                        <td>
                            @if (currentRole == "Users" &&
                                                            (rowStatus == "Approved" ||
                                                             rowStatus == "Disapproved" ||
                                                             rowStatus == "Returned"))
                            {
                                <button class="btn btn-secondary btn-sm" disabled>Edit</button>
                                <button class="btn btn-secondary btn-sm" disabled>Delete</button>
                            }
                            else
                            {
                                // ✅ Core - no Html.ActionLink
                                @* <a href="/Status/Edit/@row["bookingID"]"
                                   class="btn btn-primary btn-sm">Edit</a>
                                <a href="/Status/Delete/@row["bookingID"]"
                                   class="btn btn-danger btn-sm">Delete</a> *@
                                <button class="btn btn-primary btn-sm"
                                        onclick="openEditModal(
                                    '@row["bookingID"]',
                                    '@(row["date_returned"] != DBNull.Value ? ((DateTime)row["date_returned"]).ToString("yyyy-MM-ddTHH:mm") : "")',
                                    '@row["status"]',
                                    '@row["remarks"]')">
                                                   Edit
                                </button>

                                <button class="btn btn-danger btn-sm"
                                        onclick="openDeleteModal(
                                                 '@row["bookingID"]',
                                                 '@row["item_name"]',
                                                 '@row["departmentName"]',
                                                 '@row["status"]')">
                                                  Delete
                                </button>
                            }
                        </td>
                    }
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="11" class="text-center">
                    No @currentStatus.ToLower() bookings found.
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Pagination -->
<div class="pagination-controls mt-3">
    <button id="prevPage" class="btn btn-secondary btn-sm">Previous</button>
    <span id="pageInfo" class="mx-2"></span>
    <button id="nextPage" class="btn btn-secondary btn-sm">Next</button>
</div>

<!--modalss-->
<!-- Edit Booking Modal -->
<div class="modal fade" id="editBookingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Booking</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" id="editBookingForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="bookingid" id="edit_bookingid" />

                    <!-- Date Returned -->
                    <div class="mb-3">
                        <label class="form-label">Date Returned</label>
                        <input type="datetime-local" name="date_returned"
                               id="edit_date_returned" class="form-control" />
                    </div>

                    <!-- Status -->
                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select name="status" id="edit_status" class="form-control" required>
                            <option value="Approved">Approved</option>
                            <option value="Disapproved">Disapproved</option>
                            <option value="Returned">Returned</option>
                        </select>
                    </div>

                    <!-- Remarks -->
                    <div class="mb-3">
                        <label class="form-label">Remarks</label>
                        <input type="text" name="remarks" id="edit_remarks" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Booking Modal -->
<div class="modal fade" id="deleteBookingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Booking</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" id="deleteBookingForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="id" id="delete_bookingid" />
                    <h5>Are you sure you want to delete this booking?</h5>
                    <dl class="row mt-3">
                        <dt class="col-sm-4">Item</dt>
                        <dd class="col-sm-8" id="delete_item"></dd>
                        <dt class="col-sm-4">Department</dt>
                        <dd class="col-sm-8" id="delete_department"></dd>
                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8" id="delete_status"></dd>
                    </dl>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>
<!--end modals-->


@section Scripts {
    <script>
        // ✅ Core session via Razor (already set at top of page)
        var currentRole = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(currentRole));
        var currentStatus = '@currentStatus';

        // ✅ No Newtonsoft needed
        var statusList = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(statusList));

        var startDate = '@ViewBag.StartDate';
        var endDate = '@ViewBag.EndDate';
        var token = $('input[name="__RequestVerificationToken"]').val();

        var newBookingCounts = { 'Approved': 0, 'Disapproved': 0, 'Returned': 0 };
        var lastKnownBookings = { 'Approved': [], 'Disapproved': [], 'Returned': [] };

        var rowsPerPage = 10;
        var currentPage = 1;

        function applyPagination() {
            var rows = $("#bookingTable tbody tr");
            var totalRows = rows.length;
            var totalPages = Math.ceil(totalRows / rowsPerPage);

            rows.hide();
            var start = (currentPage - 1) * rowsPerPage;
            rows.slice(start, start + rowsPerPage).show();
            updatePaginationUI(totalPages);
        }

        function updatePaginationUI(totalPages) {
            $("#pageInfo").text("Page " + currentPage + " of " + totalPages);
            $("#prevPage").prop("disabled", currentPage <= 1);
            $("#nextPage").prop("disabled", currentPage >= totalPages);
        }

        function renderBookings(data, statusBeingRendered) {
            if (statusBeingRendered === currentStatus) {
                let tbody = "";

                if (!data || data.length === 0) {
                    tbody = `<tr><td colspan="11" class="text-center">
                              No ${statusBeingRendered.toLowerCase()} bookings found.
                             </td></tr>`;
                } else {
                    data.forEach(function(b) {
                        let showAction = currentRole !== "Users";
                        tbody += `
                            <tr>
                                <td>${b.bookingID}</td>
                                <td>${b.item}</td>
                                <td>${b.department}</td>
                                <td>${b.user}</td>
                                <td>${b.quantity}</td>
                                <td>${b.purpose}</td>
                                <td>${b.dateRequested}</td>
                                <td>${b.dateReturned}</td>
                                <td>${b.status}</td>
                                <td>${b.remarks}</td>
                                        ${showAction ? `
        <td>
            <button class="btn btn-primary btn-sm"
                onclick="openEditModal('${b.bookingID}', '${b.dateReturnedRaw ?? ''}', '${b.status}', '${b.remarks ?? ''}')">
                Edit
            </button>
            <button class="btn btn-danger btn-sm"
                onclick="openDeleteModal('${b.bookingID}', '${b.item}', '${b.department}', '${b.status}')">
                Delete
            </button>
        </td>` : ''}
                            </tr>`;
                    });
                }

                $("#bookingTable tbody").html(tbody);
                applyPagination();
            }

            if (lastKnownBookings[statusBeingRendered].length === 0)
                lastKnownBookings[statusBeingRendered] = data.map(x => String(x.bookingID));
        }

        function checkForNewBookings(newData, status) {
            var currentIds = newData.map(x => String(x.bookingID));
            var previousIds = lastKnownBookings[status] || [];
            var newOnes = currentIds.filter(id => !previousIds.includes(id));

            if (newOnes.length > 0 && status !== currentStatus) {
                newBookingCounts[status] += newOnes.length;
                updateBadge(status, newBookingCounts[status]);
                showNotification(`${newOnes.length} new ${status.toLowerCase()} booking(s)!`);
            }

            lastKnownBookings[status] = currentIds;
        }

        function updateBadge(status, count) {
            var badge = "#badge-" + status.toLowerCase();
            if (count > 0) {
                $(badge).text(count > 99 ? "99+" : count).show();
            } else {
                $(badge).hide();
            }
        }

        function showNotification(text) {
            var div = $('<div class="new-booking-notification"></div>').text(text);
            $("body").append(div);
            setTimeout(() => div.fadeOut(300, () => div.remove()), 3000);
        }

        function fetchBookings(status, startDate, endDate) {
            var params = { status: status };
            if (startDate) params.startDate = startDate;
            if (endDate) params.endDate = endDate;

            $.ajax({
                url: '@Url.Action("GetBookings", "Status")',
                type: "GET",
                data: params,
                success: function(data) {
                    renderBookings(data, status);
                    checkForNewBookings(data, status);
                },
                error: function(xhr) {
                    console.log("Error fetching bookings:", xhr.status);
                }
            });
        }

        $(document).ready(function() {
            fetchBookings(currentStatus, startDate, endDate);
            statusList.forEach(s => {
                if (s !== currentStatus) fetchBookings(s, startDate, endDate);
            });

            // $("form").submit(function(e) {
            //     e.preventDefault();
            //     startDate = $(this).find("input[name='startDate']").val();
            //     endDate = $(this).find("input[name='endDate']").val();
            //     fetchBookings(currentStatus, startDate, endDate);
            // });
                    // ✅ Only intercept the filter form
        $(".filter-form").submit(function(e) {
            e.preventDefault();
            startDate = $(this).find("input[name='startDate']").val();
            endDate = $(this).find("input[name='endDate']").val();
            fetchBookings(currentStatus, startDate, endDate);
        });


            setInterval(() => fetchBookings(currentStatus, startDate, endDate), 5000);
            setInterval(() => statusList.forEach(s => {
                if (s !== currentStatus) fetchBookings(s, startDate, endDate);
            }), 15000);

            $(".btn-group a").click(function() {
                currentStatus = $(this).text().trim();
                newBookingCounts[currentStatus] = 0;
                updateBadge(currentStatus, 0);
                lastKnownBookings[currentStatus] = [];
                currentPage = 1;
                fetchBookings(currentStatus, startDate, endDate);
            });
        });

        $("#prevPage").click(function() {
            if (currentPage > 1) { currentPage--; applyPagination(); }
        });

        $("#nextPage").click(function() {
            var totalPages = Math.ceil($("#bookingTable tbody tr").length / rowsPerPage);
            if (currentPage < totalPages) { currentPage++; applyPagination(); }
        });

                // =====================
        // Edit Modal
        // =====================
        // function openEditModal(id, dateReturned, status, remarks) {
        //     document.getElementById('edit_bookingid').value = id;
        //     document.getElementById('edit_date_returned').value = dateReturned;
        //     document.getElementById('edit_status').value = status;
        //     document.getElementById('edit_remarks').value = remarks;

        //     // Auto-fill date returned if Returned status and empty
        //     if (status === 'Returned' && !dateReturned) {
        //         var now = new Date();
        //         var formatted = now.getFullYear() + '-' +
        //             String(now.getMonth() + 1).padStart(2, '0') + '-' +
        //             String(now.getDate()).padStart(2, '0') + 'T' +
        //             String(now.getHours()).padStart(2, '0') + ':' +
        //             String(now.getMinutes()).padStart(2, '0');
        //         document.getElementById('edit_date_returned').value = formatted;
        //     }

        //     document.getElementById('editBookingForm').action = '/Status/Edit/' + id;
        //     new bootstrap.Modal(document.getElementById('editBookingModal')).show();
        // }
                function openEditModal(id, dateReturned, status, remarks) {
            document.getElementById('edit_bookingid').value = id;
            document.getElementById('edit_date_returned').value = dateReturned;
            document.getElementById('edit_remarks').value = remarks;

            // ✅ Filter dropdown options based on current status
            var statusSelect = document.getElementById('edit_status');
            statusSelect.innerHTML = ''; // clear existing options

            if (status === 'Approved') {
                // Approved → can only set to Returned
                statusSelect.innerHTML = '<option value="Returned">Returned</option>';

                // ✅ Auto-fill date returned with NOW
                var now = new Date();
                var formatted = now.getFullYear() + '-' +
                    String(now.getMonth() + 1).padStart(2, '0') + '-' +
                    String(now.getDate()).padStart(2, '0') + 'T' +
                    String(now.getHours()).padStart(2, '0') + ':' +
                    String(now.getMinutes()).padStart(2, '0');
                document.getElementById('edit_date_returned').value = formatted;

            } else if (status === 'Disapproved') {
                // Disapproved → can only stay Disapproved or go back to Pending
                statusSelect.innerHTML = `
                    <option value="Disapproved">Disapproved</option>
                    <option value="Pending">Pending</option>
                `;
                document.getElementById('edit_date_returned').value = dateReturned;

            } else {
                // Pending or other → show all options
                statusSelect.innerHTML = `
                    <option value="Approved">Approved</option>
                    <option value="Disapproved">Disapproved</option>
                    <option value="Returned">Returned</option>
                `;
                document.getElementById('edit_date_returned').value = dateReturned;
            }

            // Set current status as selected
            statusSelect.value = status === 'Approved' ? 'Returned' : status;

            document.getElementById('editBookingForm').action = '/Status/Edit/' + id;
            new bootstrap.Modal(document.getElementById('editBookingModal')).show();
        }

        // =====================
        // Delete Modal
        // =====================
        function openDeleteModal(id, item, department, status) {
            document.getElementById('delete_bookingid').value = id;
            document.getElementById('delete_item').innerText = item;
            document.getElementById('delete_department').innerText = department;
            document.getElementById('delete_status').innerText = status;

            document.getElementById('deleteBookingForm').action = '/Status/Delete/' + id;
            new bootstrap.Modal(document.getElementById('deleteBookingModal')).show();
        }


    </script>
}
